{
  "name": "jivahire-vibe-coding-interview",
  "displayName": "JivaHire Vibe Coding Interview",
  "description": "AI-aware coding interview platform by JivaHire",
  "version": "0.1.4",
  "publisher": "jivahire",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:vibe.dashboard",
    "onView:vibe.chat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibe.enterSessionKey",
        "title": "JivaHire: Enter Session Key"
      },
      {
        "command": "vibe.showBrief",
        "title": "JivaHire: Show Challenge Brief"
      },
      {
        "command": "vibe.runTests",
        "title": "JivaHire: Run Tests"
      },
      {
        "command": "vibe.submit",
        "title": "JivaHire: Submit"
      },
      {
        "command": "vibe.acceptAiChanges",
        "title": "Accept AI changes"
      },
      {
        "command": "vibe.rejectAiChanges",
        "title": "Reject"
      },
      {
        "command": "vibe.openChat",
        "title": "JivaHire: Open AI Chat"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibe-sidebar",
          "title": "JivaHire AI",
          "icon": "$(comment-discussion)"
        }
      ],
      "secondarySidebar": [
        {
          "id": "vibe-chat-panel",
          "title": "JivaHire Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "vibe-sidebar": [
        {
          "id": "vibe.dashboard",
          "name": "JivaHire",
          "type": "webview"
        }
      ],
      "vibe-chat-panel": [
        {
          "id": "vibe.chat",
          "name": "JivaHire Chat",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package --no-dependencies",
    "test": "jest"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "jest": "^30.4.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.0"
  }
}
