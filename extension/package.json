{
  "name": "jivahire-vibe-coding-interview",
  "displayName": "JivaHire Vibe Coding Interview",
  "description": "AI-aware coding interview platform by JivaHire",
  "version": "0.1.48",
  "publisher": "jivahire",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:vibe.dashboard",
    "onView:vibe.chat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibe.enterSessionKey",
        "title": "JivaHire: Enter Session Key"
      },
      {
        "command": "vibe.showBrief",
        "title": "JivaHire: Show Challenge Brief",
        "icon": "$(clock)"
      },
      {
        "command": "vibe.runTests",
        "title": "JivaHire: Run Tests",
        "icon": "$(beaker)"
      },
      {
        "command": "vibe.submit",
        "title": "JivaHire: Submit",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "vibe.acceptAiChanges",
        "title": "Accept AI changes"
      },
      {
        "command": "vibe.rejectAiChanges",
        "title": "Reject"
      },
      {
        "command": "vibe.acceptAllHunks",
        "title": "JivaHire: Accept all AI hunks",
        "icon": "$(check-all)"
      },
      {
        "command": "vibe.rejectAllHunks",
        "title": "JivaHire: Reject all AI hunks",
        "icon": "$(close-all)"
      },
      {
        "command": "vibe.acceptHunk",
        "title": "Accept this AI hunk"
      },
      {
        "command": "vibe.rejectHunk",
        "title": "Reject this AI hunk"
      },
      {
        "command": "vibe.openChat",
        "title": "JivaHire: Open AI Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "vibe.joinMeet",
        "title": "JivaHire: Join Video Call",
        "icon": "$(device-camera-video)"
      },
      {
        "command": "vibe.interceptPaste",
        "title": "JivaHire: Paste (telemetry)"
      },
      {
        "command": "vibe.attachFileToChat",
        "title": "Add to JivaHire chat",
        "category": "JivaHire"
      },
      {
        "command": "vibe.toggleDashboard",
        "title": "JivaHire: Toggle Dashboard",
        "icon": "$(jersey)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "vibe.attachFileToChat",
          "when": "!explorerResourceIsFolder",
          "group": "1_jivahire@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "vibe.attachFileToChat",
          "group": "1_jivahire@1"
        }
      ],
      "editor/context": [
        {
          "command": "vibe.attachFileToChat",
          "group": "1_jivahire@1"
        }
      ],
      "editor/title": [
        {
          "command": "vibe.showBrief",
          "when": "vibe.session.active",
          "group": "navigation@1"
        },
        {
          "command": "vibe.joinMeet",
          "when": "vibe.session.active && vibe.session.hasMeet",
          "group": "navigation@4"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vibe.interceptPaste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "editorTextFocus && !editorReadonly"
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "vibe-interview-panel",
          "title": "JivaHire Interview",
          "icon": "media/jivahire-icon.svg"
        }
      ]
    },
    "views": {
      "vibe-interview-panel": [
        {
          "id": "vibe.dashboard",
          "name": "JivaHire Dashboard",
          "type": "webview",
          "visibility": "visible"
        },
        {
          "id": "vibe.chat",
          "name": "JivaHire Chat",
          "type": "webview",
          "visibility": "visible",
          "when": "vibe.session.active"
        }
      ]
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true,
      "description": "JivaHire only reads the workspace files the candidate is asked to edit and runs commands the candidate explicitly triggers from the dashboard or status bar."
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package --no-dependencies",
    "test": "jest"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "jest": "^30.4.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.0"
  }
}
