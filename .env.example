# ── LLM / OpenRouter ──────────────────────────────────────────
OPENAI_API_KEY=sk-or-...
LLM_BASE_URL=https://openrouter.ai/api/v1
CHAT_MODEL=openai/gpt-4o-mini

# ── GitHub App ────────────────────────────────────────────────
# Create a GitHub App on your challenges org and install it with these
# permissions: Contents R/W (+ Metadata R is auto-granted). The server uses
# the App to mint short-lived, repo-scoped installation tokens for every
# clone — candidates never receive a long-lived PAT. See server/vibe/github_app.py.
GITHUB_APP_ID=123456
GITHUB_APP_INSTALLATION_ID=78901234
# PEM contents. Either keep real newlines (and quote the whole value) or
# replace newlines with the two-character \n sequence — both are accepted.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
MIIE...
-----END RSA PRIVATE KEY-----"
# Each challenge_id has its own repo at <owner>/<challenge_id>.
# e.g. challenge_id "python-ttl-cache" -> your-org/python-ttl-cache
GITHUB_CHALLENGES_OWNER=your-org

# ── Admin / Auth ──────────────────────────────────────────────
ADMIN_TOKEN=change-me-before-use

# ── Email (SendGrid) ──────────────────────────────────────────
# Leave blank to skip sending invite emails
SENDGRID_API_KEY=
FROM_EMAIL=noreply@jivahire.com
# Public URL shown to candidates in the invite email
APP_PUBLIC_URL=https://your-server.example.com

# ── Storage ───────────────────────────────────────────────────
DB_PATH=vibe.db
CHALLENGES_DIR=challenges

# ── Post-submit video (S3 + CloudFront) ───────────────────────
# Leave S3_VIDEO_BUCKET / CLOUDFRONT_DOMAIN blank to disable the feature.
# CloudFront URLs are PUBLIC — anyone with the link can view the video.
# boto3 picks up AWS creds from the standard chain (IAM role, then
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars).
AWS_REGION=us-east-1
S3_VIDEO_BUCKET=
CLOUDFRONT_DOMAIN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
