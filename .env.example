# ── LLM / OpenRouter ──────────────────────────────────────────
OPENAI_API_KEY=sk-or-...
LLM_BASE_URL=https://openrouter.ai/api/v1
CHAT_MODEL=openai/gpt-4o-mini

# ── GitHub ────────────────────────────────────────────────────
GITHUB_BOT_PAT=github_pat_...
# Each challenge_id has its own repo at <owner>/<challenge_id>.
# e.g. challenge_id "python-ttl-cache" -> your-org/python-ttl-cache
GITHUB_CHALLENGES_OWNER=your-org

# ── Admin / Auth ──────────────────────────────────────────────
ADMIN_TOKEN=change-me-before-use

# ── Email (SendGrid) ──────────────────────────────────────────
# Leave blank to skip sending invite emails
SENDGRID_API_KEY=
FROM_EMAIL=noreply@jivahire.com
# Public URL shown to candidates in the invite email
APP_PUBLIC_URL=https://your-server.example.com

# ── Storage ───────────────────────────────────────────────────
DB_PATH=vibe.db
CHALLENGES_DIR=challenges
